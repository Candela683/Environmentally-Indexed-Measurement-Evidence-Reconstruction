# Keep folder structure, but do not commit generated outputs or copied local data.
!**/.gitkeep

synthetic_bundle/external_asset_manifest.csv
synthetic_bundle/outputs/**
synthetic_bundle/review_tables/**/*.csv

synthetic_bundle/data_raw/databases/sqlite/*.sqlite
synthetic_bundle/data_raw/databases/sqlite/*.sqlite3
synthetic_bundle/data_raw/databases/sqlite/*.db

synthetic_bundle/data_raw/literature/pdfs/**/pdf/*.pdf
synthetic_bundle/data_raw/literature/pdfs/**/pdf/doi.txt
synthetic_bundle/data_raw/literature/pdfs/**/pdf/extracted_text/*.txt
synthetic_bundle/data_raw/literature/pdfs/**/pdf/extracted_tables/*.csv
synthetic_bundle/data_raw/literature/pdfs/**/pdf/**/raw_response/*.txt
synthetic_bundle/data_raw/literature/pdfs/**/pdf/**/raw_json/*.json
synthetic_bundle/data_raw/literature/pdfs/**/pdf/**/parsed_csv/*.csv
synthetic_bundle/data_raw/literature/pdfs/**/pdf/**/indexed_csv/*.csv
synthetic_bundle/data_raw/literature/pdfs/**/pdf/**/final/*.csv

synthetic_bundle/data_raw/taxonomy/gbif_backbone/*.pkl
synthetic_bundle/data_raw/taxonomy/gbif_backbone/*.zip
synthetic_bundle/data_raw/taxonomy/gbif_backbone/*.db
synthetic_bundle/data_raw/taxonomy/worms/*.txt
synthetic_bundle/data_raw/taxonomy/worms/*.xml
synthetic_bundle/data_raw/cmems/SOURCE_INVENTORY.csv
synthetic_bundle/data_raw/cmems/full_copy/**
synthetic_bundle/data_raw/cmems/netcdf_subset/**/*.nc
synthetic_bundle/data_raw/cmems/netcdf_subset/**/*.csv
